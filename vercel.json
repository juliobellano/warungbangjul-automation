{
    "builds": [
      {
        "src": "frontend/package.json",
        "use": "@vercel/static-build",
        "config": {
          "distDir": "build"
        }
      },
      {
        "src": "backend/api/index.py",
        "use": "@vercel/python",
        "config": {
          "runtime": "python3.9",
          "requirementsPath": "backend/requirements.txt"
        }
      }
    ],
    "rewrites": [
      { "source": "/api/(.*)", "destination": "/backend/api/index.py" },
      { "source": "/(.*)", "destination": "/frontend/build/$1" }
    ]
}