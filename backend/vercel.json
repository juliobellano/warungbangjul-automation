{
    "version": 2,
    "builds": [
      {
        "src": "api/index.py",
        "use": "@vercel/python",
        "config": {
          "runtime": "python3.9",
          "maxLambdaSize": "50mb"
        }
      }
    ],
    "routes": [
      { "src": "/(.*)", "dest": "/api/index.py" }
    ],
    "env": {
      "MONGODB_URL": "@mongodb_url",
      "DB_NAME": "warung_bangjul",
      "ALLOWED_ORIGINS": "https://your-frontend-vercel-url.vercel.app"
    }
  }